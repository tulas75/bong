generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String       @id @default(uuid()) @db.Uuid
  name               String
  url                String
  publicKeyMultibase  String
  privateKeyMultibase String       // Encrypted with AES-256-GCM (ENCRYPTION_KEY)
  apiKeyPrefix        String       @unique @db.VarChar(16) // First 8 chars of raw key, used for lookup
  apiKey              String       // Stored as Argon2id hash
  webhookSecret       String?      // Encrypted with AES-256-GCM, optional HMAC secret
  createdAt           DateTime     @default(now())
  deletedAt           DateTime?
  nextStatusIndex     Int          @default(0)
  badgeClasses       BadgeClass[]
  assertions         Assertion[]

  @@index([deletedAt])
}

model BadgeClass {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @db.Uuid
  externalCourseId String?
  name             String
  description      String
  imageUrl         String
  criteria         String
  achievementType  String      @default("Badge")
  templateHtml     String?
  createdAt        DateTime    @default(now())
  deletedAt        DateTime?
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  assertions       Assertion[]

  @@index([tenantId])
  @@index([externalCourseId])
  @@index([deletedAt])
}

model Assertion {
  id               String     @id @default(uuid()) @db.Uuid
  badgeClassId     String     @db.Uuid
  tenantId         String     @db.Uuid
  recipientEmail   String
  recipientName    String
  recipientSalt    String?
  issuedOn         DateTime   @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  revocationReason String?
  statusListIndex  Int?
  payloadJson      Json
  deletedAt        DateTime?
  badgeClass       BadgeClass @relation(fields: [badgeClassId], references: [id])
  tenant           Tenant     @relation(fields: [tenantId], references: [id])

  // Partial unique indexes managed via raw SQL migration
  @@index([recipientEmail])
  @@index([deletedAt])
  @@index([tenantId])
}
