{
  "name": "bong",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "bong": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node -e \"require('dotenv/config'); require('./dist/index.js')\"",
    "start": "npx prisma migrate deploy && node dist/index.js",
    "bong": "node -r dotenv/config dist/cli.js",
    "seed": "ts-node prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@digitalbazaar/data-integrity": "^2.5.0",
    "@digitalbazaar/ecdsa-multikey": "^1.8.0",
    "@digitalbazaar/ecdsa-sd-2023-cryptosuite": "^3.4.1",
    "@digitalbazaar/ed25519-multikey": "^1.3.1",
    "@digitalbazaar/eddsa-rdfc-2022-cryptosuite": "^1.3.0",
    "@digitalbazaar/vc": "^7.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "argon2": "^0.44.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "prisma": "^7.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.4",
    "@types/png-chunks-encode": "^1.0.2",
    "@types/png-chunks-extract": "^1.0.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
