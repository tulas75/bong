POSTGRES_USER=bong
POSTGRES_PASSWORD=bong
POSTGRES_DB=bong
POSTGRES_PORT=5434

APP_DOMAIN="localhost:3000"
PORT=3000
ENCRYPTION_KEY=  # 64 hex chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CORS_ORIGINS=  # Comma-separated allowed origins (e.g., https://myapp.com,https://admin.myapp.com). Empty = no CORS.

# Email (optional — if SMTP_HOST is empty, emails are skipped)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="BONG Badges <badges@example.com>"
